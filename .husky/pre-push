npm run gen:abi
npx prettier --ignore-unknown --write "abi/**/*"
git add abi/
if ! git diff --cached --quiet; then
    git commit -m "chore(\`abi/\`): update";
fi

npm run gen:docs
npx prettier --ignore-unknown --write "docs/**/*"
git add docs/
if ! git diff --cached --quiet; then
    git commit -m "chore(\`docs/\`): update";
fi
